# Copy to .env and adjust as needed. Values below match docker-compose.yml.

# Postgres connection string used by Prisma in apps/api.
# Host port is 5433 (see docker-compose.yml) to avoid clashing with other local
# Postgres instances that commonly bind 5432.
DATABASE_URL=postgresql://tally:tally@localhost:5433/tally?schema=public

# Ports
# apps/web, the Next.js dev server
WEB_PORT=3000
# apps/api, the Express server
API_PORT=4000
